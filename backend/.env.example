PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
# ⚠️ IMPORTANTE: En producción, establece una contraseña segura para MySQL.
#    Ejecuta el script: backend/migrations/set_mysql_password.sql
#    Luego actualiza DB_PASSWORD con la contraseña definida.
DB_NAME=sisge_almacen
DB_PORT=3306

JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# Origen del frontend (separar con coma si hay varios, sin espacios entre URLs)
# Ejemplo producción: FRONTEND_URL=https://app.sisge.com,https://admin.sisge.com
FRONTEND_URL=http://localhost:5173

# Contraseñas para scripts de setup (opcional - si no se definen usa defaults)
# SISGE_PASS_ADMIN=Sisge26
# SISGE_PASS_OPERARIO=Sisge2026
